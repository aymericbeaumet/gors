{
  "name": "www",
  "scripts": {
    "build:wasm": "wasm-pack build --release wasm",
    "build:v86": "bash v86/build-image.sh",
    "build:bios": "bash v86/download-bios.sh",
    "prebuild": "npm run build:wasm && npm run build:bios && npm run build:v86",
    "build": "webpack --mode=production",
    "predev": "wasm-pack build --dev wasm && npm run build:bios && npm run build:v86",
    "dev": "webpack serve --mode=development",
    "lint": "eslint ."
  },
  "dependencies": {
    "gors": "file:./wasm/pkg",
    "monaco-editor": "0.55.1",
    "v86": "^0.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "copy-webpack-plugin": "^12.0.0",
    "css-loader": "7.1.4",
    "eslint": "10.4.0",
    "favicons": "7.2.0",
    "favicons-webpack-plugin": "6.0.1",
    "file-loader": "6.2.0",
    "html-webpack-plugin": "5.6.7",
    "monaco-editor-webpack-plugin": "7.1.1",
    "prettier": "3.8.3",
    "style-loader": "4.0.0",
    "webpack": "5.106.2",
    "webpack-cli": "7.0.2",
    "wasm-pack": "^0.13.0",
    "webpack-dev-server": "5.2.4"
  }
}
